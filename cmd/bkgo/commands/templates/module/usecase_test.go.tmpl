func TestGetByID_Found(t *testing.T) {
	want := &{{.Package}}.{{.Name}}{ID: "test-id-1"}
	repo := &mock{{.Name}}Repo{
		FindByIDFn: func(ctx context.Context, id string) (*{{.Package}}.{{.Name}}, error) {
			return want, nil
		},
	}

	uc := {{.Package}}.New{{.Name}}Usecase(repo)
	got, err := uc.GetByID(context.Background(), "test-id-1")
	if err != nil {
		t.Fatalf("unexpected error: %v", err)
	}
	if got.ID != want.ID {
		t.Errorf("ID: want %s got %s", want.ID, got.ID)
	}
}

func TestGetByID_NotFound(t *testing.T) {
	repo := &mock{{.Name}}Repo{
		FindByIDFn: func(ctx context.Context, id string) (*{{.Package}}.{{.Name}}, error) {
			return nil, errs.NotFound("{{.Name}} not found")
		},
	}

	uc := {{.Package}}.New{{.Name}}Usecase(repo)
	_, err := uc.GetByID(context.Background(), "missing-id")
	if err == nil {
		t.Fatal("expected not-found error")
	}
	ae, ok := errs.IsAppError(err)
	if !ok || ae.Code != "NOT_FOUND" {
		t.Errorf("expected NOT_FOUND AppError, got: %v", err)
	}
}

